---
import MainLayout from "../layouts/MainLayout.astro";
import "../styles/global.css";
---

<MainLayout 
    title="404 - Page Not Found | Nikshaan"
    description="The page you're looking for doesn't exist. Return to homepage."
>
    <div class="min-h-[100svh] w-full bg-[#111111] text-white flex flex-col justify-center items-center gap-4 p-4">
        <h1 class="type-hero-display">404</h1>
        <p class="type-h4 font-normal text-neutral-400">Page does not exist!</p>
        <a 
            class="cursor-pointer px-6 py-3 bg-purple-600 hover:bg-purple-700 rounded-full transition-colors type-body font-medium" 
            href="/" 
            aria-label="Go back to homepage"
        >
            Go back home
        </a>
    </div>
</MainLayout>