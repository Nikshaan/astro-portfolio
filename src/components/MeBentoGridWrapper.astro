---
import MeBentoGrid from "./MeBentoGrid";
import { getImage } from "astro:assets";
import collegeLogo from "../data/djsce-logo.avif";
import aryaLogo from "../data/arya.avif";
import codeAIlogo from "../data/codeai.avif";
import varakLogo from "../data/varak.avif";
import mentoriaLogo from "../data/mentoria.avif";
import gssocLogo from "../data/gssoc.avif";
import winIcon from "../data/winIcon.avif";
import nikshaanRaw from "../data/NIKSHAAN.avif";

const { beeImage } = Astro.props;

const locationBg = await getImage({
    src: nikshaanRaw,
    format: "avif",
    widths: [400, 640, 900, 1200],
    width: 900,
    quality: 80,
});

const optimizedProfileImage = await getImage({
    src: nikshaanRaw,
    format: "avif",
    widths: [150, 300, 400],
    width: 400,
    quality: 85,
});

const optimizedImages = {
    beeImage: beeImage,
    locationBg: locationBg,
    profileImage: optimizedProfileImage,
    collegeLogo: await getImage({
        src: collegeLogo,
        format: "avif",
        widths: [120, 180, 240, 360],
        width: 360,
        quality: 90,
    }),
    aryaLogo: await getImage({
        src: aryaLogo,
        format: "avif",
        widths: [120, 180, 240, 360],
        width: 360,
        quality: 90,
    }),
    codeAIlogo: await getImage({
        src: codeAIlogo,
        format: "avif",
        widths: [60, 90, 120, 180],
        width: 180,
        quality: 90,
    }),
    varakLogo: await getImage({
        src: varakLogo,
        format: "avif",
        widths: [60, 90, 120, 180],
        width: 180,
        quality: 90,
    }),
    mentoriaLogo: await getImage({
        src: mentoriaLogo,
        format: "avif",
        widths: [60, 90, 120, 180],
        width: 180,
        quality: 90,
    }),
    gssocLogo: await getImage({
        src: gssocLogo,
        format: "avif",
        widths: [60, 90, 120, 180],
        width: 180,
        quality: 90,
    }),
    winIcon: await getImage({
        src: winIcon,
        format: "avif",
        widths: [60, 80, 100, 160, 200],
        width: 200,
        quality: 90,
    }),
};
---

<link
    rel="preload"
    as="image"
    href={locationBg.src}
    imagesrcset={locationBg.attributes.srcset}
    imagesizes="(max-width: 640px) 400px, 640px"
/>

<MeBentoGrid client:idle optimizedImages={optimizedImages} />
