---
import { Tooltips } from "astro-tooltips";

interface Props {
    title: string;
    description: string;
    preloadImage?: string;
    profileImage?: string;
}

import beeImage from "../data/bee.avif";
import { getImage } from "astro:assets";
import VercelAnalytics from "../components/VercelAnalytics.astro";
import Footer from "../components/Footer";

const { title, description, preloadImage, profileImage } = Astro.props;

const favicon = await getImage({
    src: beeImage,
    format: "png",
    width: 32,
    height: 32,
});
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/png" href={favicon.src} />
        <link rel="manifest" href="/manifest.json" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="generator" content={Astro.generator} />
        <title>{title}</title>
        <meta content={description} name="description" />
        <meta content="Nikshaan Shetty" name="author" />
        <meta content="index, follow" name="robots" />
        <link rel="canonical" href="https://nikshaan.vercel.app/" />

        <meta content={title} property="og:title" />
        <meta content={description} property="og:description" />
        <meta content="website" property="og:type" />
        <meta content="https://nikshaan.vercel.app/" property="og:url" />
        <meta
            content="https://nikshaan.vercel.app/favicon.svg"
            property="og:image"
        />
        <meta content="1200" property="og:image:width" />
        <meta content="630" property="og:image:height" />
        <meta content="en_IN" property="og:locale" />
        <meta content="Nikshaan Shetty Portfolio" property="og:site_name" />

        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta
            name="twitter:image"
            content="https://nikshaan.vercel.app/favicon.svg"
        />

        <meta
            name="theme-color"
            content="#111111"
            media="(prefers-color-scheme: dark)"
        />
        <meta
            name="theme-color"
            content="#ffffff"
            media="(prefers-color-scheme: light)"
        />
        <meta name="color-scheme" content="dark light" />
        <meta name="mobile-web-app-capable" content="yes" />
        <meta name="apple-mobile-web-app-capable" content="yes" />
        <meta
            name="apple-mobile-web-app-status-bar-style"
            content="black-translucent"
        />
        <meta name="apple-mobile-web-app-title" content="Nikshaan" />
        <link
            rel="apple-touch-icon"
            sizes="180x180"
            href="/apple-touch-icon.png"
        />
        <link rel="canonical" href="https://nikshaan.vercel.app/" />
        <link rel="manifest" href="/manifest.json" />

        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

        <link
            rel="preload"
            href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
            as="style"
        />
        <link
            href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
            rel="stylesheet"
            media="print"
            onload="this.media='all'"
        />
        <noscript>
            <link
                rel="stylesheet"
                href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
            />
        </noscript>

        <link rel="dns-prefetch" href="https://api.github.com" />
        <link rel="dns-prefetch" href="https://ws.audioscrobbler.com" />
        <link rel="dns-prefetch" href="https://api.spotify.com" />
        <link rel="dns-prefetch" href="https://accounts.spotify.com" />
        <link rel="dns-prefetch" href="https://www.linkedin.com" />
        <link rel="dns-prefetch" href="https://github.com" />
        <link rel="dns-prefetch" href="https://vitals.vercel-insights.com" />

        {
            preloadImage && (
                <link
                    rel="preload"
                    as="image"
                    href={preloadImage}
                    fetchpriority="high"
                    type="image/avif"
                />
            )
        }
        {
            profileImage && (
                <link
                    rel="preload"
                    as="image"
                    href={profileImage}
                    fetchpriority="high"
                    type="image/avif"
                />
            )
        }

        <script type="speculationrules">
            {
                "prefetch": [
                    {
                        "urls": ["https://nikshaan.vercel.app/"],
                        "eagerness": "moderate"
                    }
                ]
            }
        </script>

        <Tooltips interactive={false} delay={[0, 50]} />

        <script is:inline>
            (function () {
                try {
                    var theme = localStorage.getItem("theme");
                    if (theme) {
                        document.documentElement.setAttribute(
                            "data-theme",
                            theme,
                        );
                    }
                } catch (e) {}

                if (
                    "connection" in navigator &&
                    navigator.connection.saveData
                ) {
                    document.documentElement.classList.add("save-data");
                }

                window.addEventListener("vite:preloadError", function (e) {
                    const reloadKey = "vite_chunk_err_reload";
                    const lastReload = sessionStorage.getItem(reloadKey);
                    if (
                        !lastReload ||
                        Date.now() - parseInt(lastReload) > 10000
                    ) {
                        sessionStorage.setItem(
                            reloadKey,
                            Date.now().toString(),
                        );
                        window.location.reload();
                    }
                });

                window.addEventListener("unhandledrejection", function (e) {
                    if (
                        e.reason &&
                        e.reason.message &&
                        e.reason.message.includes(
                            "Failed to fetch dynamically imported module",
                        )
                    ) {
                        e.preventDefault();
                        const reloadKey = "import_chunk_err_reload";
                        const lastReload = sessionStorage.getItem(reloadKey);
                        if (
                            !lastReload ||
                            Date.now() - parseInt(lastReload) > 10000
                        ) {
                            sessionStorage.setItem(
                                reloadKey,
                                Date.now().toString(),
                            );
                            window.location.reload();
                        }
                    }
                });
            })();
        </script>
    </head>
    <body class="h-full bg-black text-neutral-50">
        <slot />
        <Footer client:idle />
        <VercelAnalytics />
        <script
            type="application/ld+json"
            set:html={JSON.stringify({
                "@context": "https://schema.org",
                "@type": "Person",
                name: "Nikshaan Shetty",
                url: "https://nikshaan.vercel.app",
                image: "https://nikshaan.vercel.app/favicon.svg",
                sameAs: [
                    "https://www.linkedin.com/in/nikshaan-shetty/",
                    "https://github.com/Nikshaan",
                ],
                jobTitle: "AI/ML Student & Software Developer",
                worksFor: {
                    "@type": "Organization",
                    name: "Mentoria",
                },
                alumniOf: {
                    "@type": "CollegeOrUniversity",
                    name: "Dwarkadas J. Sanghvi College of Engineering",
                    address: {
                        "@type": "PostalAddress",
                        addressLocality: "Mumbai",
                        addressCountry: "IN",
                    },
                },
                knowsAbout: [
                    "Artificial Intelligence",
                    "Machine Learning",
                    "React",
                    "Python",
                    "LLM",
                    "FastAPI",
                ],
            })}
        />
    </body>
</html>

<style>
    body {
        background-color: #111111;
        overflow-x: hidden;
        transition:
            background-color 0.3s ease,
            color 0.3s ease;
        margin: 0;
        padding: 0;
    }

    [data-theme="light"] body {
        background-color: #ffffff;
        color: #000000;
    }
</style>

<script>
    async function initLenis() {
        const Lenis = (await import("lenis")).default;

        const lenis = new Lenis({
            duration: 1.2,
            easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
            orientation: "vertical",
            gestureOrientation: "vertical",
            smoothWheel: true,
            wheelMultiplier: 1,
            touchMultiplier: 2,
            infinite: false,
            autoRaf: true,
        });

        (window as any).lenis = lenis;

        document.addEventListener("astro:before-swap", () => {
            lenis.destroy();
            delete (window as any).lenis;
        });
    }

    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initLenis);
    } else {
        initLenis();
    }
</script>
